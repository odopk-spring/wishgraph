{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.wishgraph/hooks/memory_sync.py\" session-start --host codex",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; py -3 (Join-Path $root '.wishgraph/hooks/memory_sync.py') session-start --host codex\"",
            "timeout": 30,
            "statusMessage": "Checking WishGraph handoff state"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.wishgraph/hooks/memory_sync.py\" user-prompt-submit --host codex",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; py -3 (Join-Path $root '.wishgraph/hooks/memory_sync.py') user-prompt-submit --host codex\"",
            "timeout": 10,
            "statusMessage": "Routing WishGraph command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|Write|Edit|MultiEdit|NotebookEdit|apply_patch|mcp__.*__.*(?:write|edit|patch|create|delete|move|rename|update).*)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.wishgraph/hooks/memory_sync.py\" pre-tool-use --host codex",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; py -3 (Join-Path $root '.wishgraph/hooks/memory_sync.py') pre-tool-use --host codex\"",
            "timeout": 30,
            "statusMessage": "Checking WishGraph memory sync"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.wishgraph/hooks/memory_sync.py\" stop --host codex",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; py -3 (Join-Path $root '.wishgraph/hooks/memory_sync.py') stop --host codex\"",
            "timeout": 30,
            "statusMessage": "Verifying WishGraph closeout"
          }
        ]
      }
    ]
  }
}
