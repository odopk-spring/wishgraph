{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.wishgraph/hooks/memory_sync.py\" session-start",
            "timeout": 30,
            "statusMessage": "Checking WishGraph handoff state"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.wishgraph/hooks/memory_sync.py\" pre-tool-use",
            "timeout": 30,
            "statusMessage": "Checking WishGraph memory sync"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.wishgraph/hooks/memory_sync.py\" stop",
            "timeout": 30,
            "statusMessage": "Verifying WishGraph closeout"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.wishgraph/hooks/memory_sync.py\" task-completed",
            "timeout": 30,
            "statusMessage": "Verifying WishGraph task closeout"
          }
        ]
      }
    ]
  }
}
